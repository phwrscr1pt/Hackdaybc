<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Search: <%= query %> — ByteWise</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/search/css/style.css">
</head>
<body>
  <!-- Navigation -->
  <nav class="navbar">
    <div class="nav-container">
      <a href="/search/" class="nav-brand">
        <div class="brand-icon"><i class="bi bi-braces-asterisk"></i></div>
        <div class="brand-text">
          <span class="brand-name">ByteWise</span>
          <span class="brand-tagline">Developer Insights</span>
        </div>
      </a>
      <div class="nav-links">
        <a href="/search/" class="nav-link">Home</a>
        <a href="#" class="nav-link">Tutorials</a>
        <a href="#" class="nav-link">News</a>
        <a href="#" class="nav-link">About</a>
      </div>
      <div class="nav-actions">
        <form action="/search/search" method="GET" class="nav-search">
          <input type="text" name="q" value="<%= query %>" placeholder="Search articles...">
          <button type="submit"><i class="bi bi-search"></i></button>
        </form>
      </div>
    </div>
  </nav>

  <!-- Search Results Header -->
  <section class="search-header">
    <div class="search-header-content">
      <nav class="breadcrumb">
        <a href="/search/"><i class="bi bi-house"></i> Home</a>
        <i class="bi bi-chevron-right"></i>
        <span>Search</span>
      </nav>
      <h1><i class="bi bi-search"></i> Search Results</h1>
      <p class="search-query">Showing results for: <strong><%- query %></strong></p>
      <div class="search-stats">
        <span class="result-count"><%= results.length %> article<%= results.length !== 1 ? 's' : '' %> found</span>
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <main class="container">
    <% if (results.length === 0) { %>
    <!-- No Results -->
    <div class="no-results">
      <div class="no-results-icon"><i class="bi bi-search"></i></div>
      <h2>No articles found</h2>
      <p>We couldn't find any articles matching "<strong><%- query %></strong>"</p>
      <div class="no-results-suggestions">
        <h4>Suggestions:</h4>
        <ul>
          <li>Check your spelling and try again</li>
          <li>Try using different keywords</li>
          <li>Use more general search terms</li>
        </ul>
      </div>
      <a href="/search/" class="btn-back"><i class="bi bi-arrow-left"></i> Back to Home</a>
    </div>
    <% } else { %>
    <!-- Results Grid -->
    <section class="search-results">
      <div class="posts-grid">
        <% results.forEach((a, index) => { %>
        <article class="post-card">
          <div class="post-image post-image-<%= index % 4 %>">
            <span class="post-category"><%= ['Tutorial', 'News', 'Tips', 'Guide'][index % 4] %></span>
          </div>
          <div class="post-content">
            <div class="post-meta">
              <span><i class="bi bi-calendar3"></i> Mar <%= 5 - index %>, 2026</span>
              <span><i class="bi bi-chat-dots"></i> <%= (index + 1) * 3 %> comments</span>
            </div>
            <h3><%= a.title %></h3>
            <p><%= a.summary %></p>
            <div class="post-footer">
              <div class="author-mini">
                <div class="author-avatar-sm"><%= a.title.charAt(0).toUpperCase() %></div>
                <span>@dev_user<%= index + 1 %></span>
              </div>
              <a href="#" class="read-more">Read more <i class="bi bi-arrow-right"></i></a>
            </div>
          </div>
        </article>
        <% }) %>
      </div>
    </section>
    <% } %>

    <!-- Back Navigation -->
    <div class="back-nav">
      <a href="/search/" class="btn-back"><i class="bi bi-arrow-left"></i> Back to Home</a>
    </div>
  </main>

  <!-- Footer -->
  <footer class="footer">
    <div class="footer-content">
      <div class="footer-brand">
        <div class="brand-icon"><i class="bi bi-braces-asterisk"></i></div>
        <span>ByteWise</span>
      </div>
      <p>&copy; 2026 ByteWise Developer Blog. Part of LeaguesOfCode Thailand.</p>
      <div class="footer-links">
        <a href="#"><i class="bi bi-twitter-x"></i></a>
        <a href="#"><i class="bi bi-github"></i></a>
        <a href="#"><i class="bi bi-discord"></i></a>
        <a href="#"><i class="bi bi-linkedin"></i></a>
      </div>
    </div>
  </footer>
</body>
</html>
